import os
from datetime import datetime


class PasswordAnalyzer:
    def __init__(self, password):
        self.password = password
        self.score = 0
        self.feedback = []

    def check_length(self):
        if len(self.password) < 8:
            self.feedback.append("❌ Too short - use at least 8 characters")
        elif len(self.password) >= 12:
            self.score += 2
            self.feedback.append("✅ Great length!")
        else:
            self.score += 1
            self.feedback.append("⚠️ Acceptable length but longer is better")

    def check_uppercase(self):
        if any(c.isupper() for c in self.password):
            self.score += 1
            self.feedback.append("✅ Contains uppercase letters")
        else:
            self.feedback.append("❌ Add uppercase letters")

    def check_lowercase(self):
        if any(c.islower() for c in self.password):
            self.score += 1
            self.feedback.append("✅ Contains lowercase letters")
        else:
            self.feedback.append("❌ Add lowercase letters")

    def check_numbers(self):
        if any(c.isdigit() for c in self.password):
            self.score += 1
            self.feedback.append("✅ Contains numbers")
        else:
            self.feedback.append("❌ Add numbers")

    def check_special_characters(self):
        special = "!@#$%^&*()_+-=[]{}|;:,.<>?"
        if any(c in special for c in self.password):
            self.score += 1
            self.feedback.append("✅ Contains special characters")
        else:
            self.feedback.append("❌ Add special characters like !@#$")

    def get_strength(self):
        if self.score <= 1:
            return "WEAK"
        elif self.score <= 3:
            return "MEDIUM"
        else:
            return "STRONG"

    def analyze(self):
        self.check_length()
        self.check_uppercase()
        self.check_lowercase()
        self.check_numbers()
        self.check_special_characters()


# Run the analyzer
desktop = os.path.join(os.path.expanduser("~"), "OneDrive", "Desktop")
log_path = os.path.join(desktop, "Logs", "password_log.txt")

while True:
    password = input("Enter a password to analyze: ")
    analyzer = PasswordAnalyzer(password)
    analyzer.analyze()

    print("\n--- Password Analysis ---")
    print(f"Password: {password}")
    print(f"Strength: {analyzer.get_strength()}")
    print(f"Score: {analyzer.score}/6")
    print("\nFeedback:")
    for item in analyzer.feedback:
        print(item)

    # Log the result
    with open(log_path, "a") as log_file:
        log_file.write(f"\n[{datetime.now()}] Password Strength: {analyzer.get_strength()} | Score: {analyzer.score}/6\n")
        for item in analyzer.feedback:
            log_file.write(f"{item}\n")

    if analyzer.get_strength() == "STRONG":
        print("\n✅ Great password! You're good to go!")
        break
    else:
        print("\n⚠️ Please try a stronger password!\n")
